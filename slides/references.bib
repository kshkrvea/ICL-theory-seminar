  author = {{Rodriguez-Opazo}, Cristian and {Marrese-Taylor}, Edison and Abbasnejad, Ehsan and Damirchi, Hamed and Jara, Ignacio M. and {Bravo-Marquez}, Felipe and van den Hengel, Anton},
  year = 2023,
