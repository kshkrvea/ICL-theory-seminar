@misc{erdoganGeometricFlowModels2025,
  title = {Geometric {{Flow Models}} over {{Neural Network Weights}}},
  shorttitle = {Geometric {{Flow Models}} over {{NN Weights}}},
  author = {Erdogan, Ege},
  year = 2025,
