@misc{eremeevGraphPFNPriorDataFitted2026,
  title = {{{GraphPFN}}: {{A Prior-Data Fitted Graph Foundation Model}}},
  shorttitle = {{{GraphPFN}}},
  author = {Eremeev, Dmitry and Platonov, Oleg and Bazhenov, Gleb and Babenko, Artem and Prokhorenkova, Liudmila},
  year = 2026,
