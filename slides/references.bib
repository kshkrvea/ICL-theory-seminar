@misc{wangFunctionalityOrientedLLMMerging2026,
  title = {Functionality-{{Oriented LLM Merging}} on the {{Fisher--Rao Manifold}}},
  author = {Wang, Jiayu and Ye, Zuojun and Yin, Wenpeng},
  year = 2026,
